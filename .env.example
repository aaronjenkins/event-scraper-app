# Copy to .env and fill in. Every value has a safe default except the DB URL.

# ---- Database (scraper + bot) --------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/events
# Optional per-component overrides (fall back to DATABASE_URL):
# JOLLYBOAT_DATABASE_URL=
# CINCYEVENTBOT_DATABASE_URL=

# ---- LLM classification (optional; OpenAI-compatible / LiteLLM) -----------
LITELLM_URL=http://localhost:4000
LITELLM_KEY=changeme
# Set to 0 to disable LLM classification entirely:
# JOLLYBOAT_LLM=1
# CINCYEVENTBOT_LLM=1
# JOLLYBOAT_LLM_MODEL=claude-haiku
# CINCYEVENTBOT_LLM_MODEL=claude-haiku

# ---- Headless-browser render service (optional; JS-heavy venues) ----------
# A microservice exposing POST /render and POST /capture.
RENDER_URL=http://localhost:7250
RENDER_API_KEY=changeme
# RENDER_TIMEOUT_MS=60000

# ---- SerpAPI (optional; Google Events source) -----------------------------
# https://serpapi.com — scraper reads SERPAPI_KEY, bot reads SERP_API_KEY.
SERPAPI_KEY=
SERP_API_KEY=

# ---- Signal digest webhook (optional) -------------------------------------
# A webhook expecting POST /send {message, group_id, api_key}. Leave unset to
# disable the daily digest and scraper drop-alerts.
SIGNAL_WEBHOOK_URL=http://localhost:7200
SIGNAL_WEBHOOK_KEY=
SIGNAL_GROUP_ID=

# ---- Bot output -----------------------------------------------------------
# Where the bot writes events.json (serve this at the UI's /data/events.json).
EVENTS_JSON_PATH=/var/cache/eventscraper/events.json
# Link included in the digest message:
SPA_URL=https://events.example.com/
# LOOKAHEAD_DAYS=7
